{
  "name": "clinical-appointment-backend",
  "version": "1.0.0",
  "description": "Backend API for Clinical Appointment Scheduling System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:ci": "NODE_ENV=test jest --ci --coverage --watchAll=false",
    "seed": "node scripts/seedDatabase.js",
    "seed:test": "NODE_ENV=test node scripts/seedDatabase.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t clinical-backend .",
    "docker:run": "docker run -p 5000:5000 clinical-backend",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend",
    "health": "curl -f http://localhost:5000/api/health || exit 1",
    "migrate": "node scripts/migrate.js",
    "migrate:run": "node scripts/migrate.js run",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:create": "node scripts/migrate.js create",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "backup": "node scripts/backup.js",
    "backup:create": "node scripts/backup.js create",
    "backup:mysql": "node scripts/backup.js create mysql",
    "backup:mongodb": "node scripts/backup.js create mongodb",
    "backup:files": "node scripts/backup.js create files",
    "backup:list": "node scripts/backup.js list",
    "backup:restore": "node scripts/backup.js restore",
    "backup:cleanup": "node scripts/backup.js cleanup",
    "backup:stats": "node scripts/backup.js stats",
    "logs": "tail -f logs/app.log",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix"
  },
  "keywords": [
    "medical",
    "appointment",
    "scheduling",
    "healthcare",
    "api"
  ],
  "author": "Clinical Appointment System Team",
  "license": "MIT",
  "dependencies": {
    "agenda": "^5.0.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.4",
    "nodemailer-express-handlebars": "^6.1.0",
    "pdf-parse": "^1.1.1",
    "prom-client": "^14.2.0",
    "redis": "^4.6.7",
    "sharp": "^0.32.5",
    "socket.io": "^4.7.2",
    "twilio": "^4.15.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "eslint": "^8.47.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
